{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start All",
      "dependsOn": ["Frontend", "Backend", "Worker"],
      "dependsOrder": "parallel",
      "runOptions": { "runOn": "folderOpen" }
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run dev",
      "presentation": {
        "group": "dev",
        "panel": "dedicated"
      }
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": "npx json-server db.json",
      "presentation": {
        "group": "dev",
        "panel": "dedicated"
      }
    },
    {
      "label": "Worker",
      "type": "shell",
      "command": "node index.js",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "group": "dev",
        "panel": "dedicated"
      }
    }
  ]
}